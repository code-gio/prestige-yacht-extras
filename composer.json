{
    "name": "codegio/prestige-yacht-extras",
    "description": "Branded PDF spec sheets and tools for Prestige Yacht boat listings.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "dompdf/dompdf": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PrestigeYacht\\Extras\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    },
    "minimum-stability": "stable"
}
